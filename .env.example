# Backend Environment Variables
FLASK_ENV=production
PYTHON_VERSION=3.11

# MongoDB Configuration (Optional - leave blank for file-based storage)
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/sentiment_analysis

# Frontend API URL (set automatically by Render)
REACT_APP_API_URL=https://your-backend-service.onrender.com/api
